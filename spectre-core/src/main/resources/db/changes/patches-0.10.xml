<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">


    <changeSet id="202605191511" author="vudsen">
        <addColumn tableName="arthas_instance">
            <column name="paths" type="varchar(128)"/>
        </addColumn>
    </changeSet>
    <changeSet id="202605211016" author="vudsen">
        <delete tableName="arthas_instance">
            <where>paths IS NULL</where>
        </delete>
    </changeSet>

    <changeSet id="202605221009" author="vudsen">
        <createTable tableName="channel">
            <column name="id" type="java.sql.Types.VARCHAR(64)"/>
            <column name="instance_ids" type="java.sql.Types.VARCHAR(1024)"/>
            <column name="last_access" type="JAVA.SQL.TYPES.DATETIME"/>
        </createTable>
        <dropColumn tableName="arthas_instance">
            <column name="channel_id"/>
        </dropColumn>
    </changeSet>

</databaseChangeLog>